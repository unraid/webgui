            exec($cmd, $pid);
          }

        } else {
          $reply['error'] = _('Invalid target name');
        }
      }
      break;
    case 11: // change owner

      // return status of running action
      if (!empty($pid)) {
        $file_line = exec("tail -2 $status | grep -Pom1 \"^.+ of '\\K[^']+\"");
        $reply['status'] = json_encode([
          'action' => $action,
          'text' => [_('Updating').'... '.mb_strimhalf($file_line, 70, '...')]
        ]);

