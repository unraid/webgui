            # -o = overwrite, -n = never overwrite (keep existing)
            unzip $unzip_overwrite_flag "$archive" >/dev/null
            unzip_exit=\$?
            wait \$poller_pid 2>/dev/null
            exit \$unzip_exit
          } >$status 2>$error & echo \$!
          BASH;

