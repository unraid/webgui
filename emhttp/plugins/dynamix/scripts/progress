#!/bin/bash
# ##################################################################### #
# progress.sh - parse zip, tar or unzip stdout and emit progress
#
# Copyright 2026 Marc Gutt, Gutt.IT
#
# This program is free software; you can redistribute it and/or
# modify it under the terms of the GNU General Public License
# as published by the Free Software Foundation; version 2.
#
# This program is distributed in the hope that it will be useful,
# but WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
# GNU General Public License for more details.
#
# You should have received a copy of the GNU General Public License
# along with this program; if not, see <https://www.gnu.org/licenses/>.
# ##################################################################### #
#
# Usage (piped process auto-detected):
#  zip -r -du -ds Xm archive.zip -- files... | progress.sh
#  unzip -^ -o archive.zip -d /dest/dir      | progress.sh
#  tar -xvf archive.tar -C /dest/dir         | progress.sh
#  tar -cv --checkpoint=N --checkpoint-action=exec="printf 'CHUNK\n'" -f archive.tar -- files... | progress.sh
#
# Verbose/debug output (stderr):
#  ... | progress.sh -v
#  ... | progress.sh --verbose
#
# Human-readable progress (stderr) when stdout is not a TTY:
#  tar ... | progress.sh >/dev/null
#  tar ... | progress.sh | tee file >/dev/null
#
# Required invocation:        CWD should be the source dir (zip/tar compress) or destination dir
#                             (unzip/tar extract) when the pipeline runs, e.g.:
#                               cd /dest && tar -xvf archive.tar | progress
#                             progress inherits that CWD and uses it to locate files via stat.
# Required zip options:       -du  -ds Xm
# Required unzip options:     -^ (restore control chars in filenames; without it, unzip strips
#                                 them on extraction so progress cannot find the file on disk)
# Required tar compress options: -v  --checkpoint=N  --checkpoint-action=exec="printf 'CHUNK\n'"
# Required tar extract options:  -v
#
# Output (stdout), fields separated by space:
#   TOTAL bytes         (not guaranteed; omitted if size cannot be determined in time)
#   FILE timestamp size filename
#   CHUNK timestamp bytes
#   INFO message
#
# Exit code: 1 if no parent compress process (zip/tar/unzip) was found

debug=
progress_nl=
force_progress=
while [[ ${1-} == -* ]]; do
  case ${1-} in
    -v|--verbose)           debug=1 ;;
    --progress-newline)     progress_nl=1 ;;
    --progress)             force_progress=1 ;;
  esac
  shift
done
dbg() { [[ $debug ]] && echo "[DEBUG] $*" >&2; return 0; }
dbg "debug=$debug progress_nl=$progress_nl force_progress=$force_progress"

# Human-readable progress on stderr when stdout is not a TTY.
# Covers: | progress.sh >/dev/null  and  | progress.sh | tee file >/dev/null
# --progress forces the bar even without a TTY (e.g. redirected stderr).
show_progress=
[[ $force_progress || ( ! -t 1 && -t 2 ) ]] && show_progress=1
dbg "show_progress=$show_progress"

# Resolve sleep path once; avoids bash probing ./sleep when CWD is inside the
# extraction destination (unzip sets its CWD there before exec).
_sleep_cmd=$(command -v sleep)

# Progress state
_prog_total=0
_prog_done=0
_prog_fname=
_prog_chunk_t=
_prog_chunk_done=0
_prog_bar_total=10
_prog_total_str=
_prog_last_speed=0
_prog_never_rendered=1
_prog_speed_w=10
_prog_eta_w=6

# Format bytes with one decimal (truncated, not rounded)
_prog_fmt_bytes() {
  local b=$1 v unit
  if   [[ $b -ge 1073741824 ]]; then v=$(( b * 10 / 1073741824 )); unit=GB
  elif [[ $b -ge 1048576    ]]; then v=$(( b * 10 / 1048576 ));    unit=MB
  elif [[ $b -ge 1024       ]]; then v=$(( b * 10 / 1024 ));       unit=KB
  else echo "$b B"; return
  fi
  printf '%d.%d %s\n' $((v/10)) $((v%10)) "$unit"
}

_prog_render() {
  [[ ! $show_progress ]] && return
  # Use sub-second timestamps (EPOCHREALTIME) for accurate speed on fast transfers.
  local now=$EPOCHREALTIME  
  if [[ $_prog_chunk_t ]]; then
    local new_speed
    # 0.05s threshold avoids division by near-zero on first call; keep last known speed otherwise.
    new_speed=$(awk \
      -v now="$now" -v t="$_prog_chunk_t" -v done="$(( _prog_done - _prog_chunk_done ))" \
      'BEGIN{ dt=now-t; if (dt > 0.05) print int(done/dt); else print -1 }')
    [[ $new_speed -ge 0 ]] && _prog_last_speed=$new_speed
  fi
  local speed=$_prog_last_speed
  local speed_str eta_str done_str pct right_side
  done_str=$(_prog_fmt_bytes "$_prog_done")
  if [[ $speed -gt 0 ]]; then
    speed_str=$(_prog_fmt_bytes "$speed")/s
  else
    speed_str='--'
  fi
  if [[ $_prog_total -gt 0 ]]; then
    pct=$(( _prog_done * 100 / _prog_total ))
    if [[ $speed -gt 0 ]]; then
      local eta=$(( (_prog_total - _prog_done) / speed ))
      if [[ $eta -ge 3600 ]]; then
        eta_str=$(( eta / 3600 ))h$(( (eta % 3600) / 60 ))m
      elif [[ $eta -ge 60 ]]; then
        eta_str=$(( eta / 60 ))m$(( eta % 60 ))s
      else
        eta_str="${eta}s"
      fi
    else
      eta_str='--'
    fi
    right_side=$(printf '%3d%%  %-*s / %s  %-*s  ETA %-*s' \
      "$pct" \
      "${#_prog_total_str}" "$done_str" "$_prog_total_str" \
      "$_prog_speed_w" "$speed_str" \
      "$_prog_eta_w" "$eta_str")
  else
    # TOTAL not yet known: show done + speed only, no percent/ETA
    right_side=$(printf '  ?%%  %s  %s' "$done_str" "$speed_str")
    pct=0
  fi
  local cols=${COLUMNS:-80}
  # Filename: truncate to full terminal width
  local fname="$_prog_fname"
  if [[ ${#fname} -gt $cols ]]; then
    fname="...${fname: -$((cols - 3))}"
  fi
  local filled=$(( pct * _prog_bar_total / 100 ))
  local empty=$(( _prog_bar_total - filled ))
  local bar_fill bar_empty
  printf -v bar_fill '%*s' $filled ''; bar_fill=${bar_fill// /█}
  printf -v bar_empty '%*s' $empty ''; bar_empty=${bar_empty// /░}
  if [[ $progress_nl ]]; then
    printf '%s\n[%s%s] %s\n' "$fname" "$bar_fill" "$bar_empty" "$right_side" >&2
  else
    if [[ ! $_prog_never_rendered ]]; then
      # Cursor is at end of bar line; go up to fname line and redraw both
      printf '\033[1A' >&2
    fi
    printf '\r\033[K%s\n\r\033[K[%s%s] %s' "$fname" "$bar_fill" "$bar_empty" "$right_side" >&2
    _prog_never_rendered=
  fi
}

_prog_total_line() {
  _prog_total=$1
  [[ ! $show_progress ]] && return
  _prog_chunk_t=$EPOCHREALTIME
  _prog_chunk_done=0
  _prog_last_speed=0
  _prog_never_rendered=1
  # _prog_bar_total is fixed at TOTAL time so the bar width never changes mid-transfer.
  # _prog_speed_w/_prog_eta_w pad speed/eta to constant widths for the same reason.
  _prog_total_str=$(_prog_fmt_bytes "$_prog_total")
  # Max speed width: "999.9 MB/s" = 10 chars; max eta width: "99h99m" = 6 chars.
  # Right-side format: '%3d%%  %-*s / %s  %-*s  ETA %-*s' →
  #   3 + 1(%) + 2(spaces)            = 6
  # + len(total_str) + 3(' / ') + len(total_str) + 2(spaces)
  # + speed_w + 2(spaces)
  # + 4('ETA ') + eta_w
  local right_w=$(( 17 + 2 * ${#_prog_total_str} + _prog_speed_w + _prog_eta_w ))
  local cols=${COLUMNS:-80}
  # [bar] right_side: 1('[') + bar + 2('] ') + right_w = cols
  _prog_bar_total=$(( cols - 3 - right_w ))
  [[ $_prog_bar_total -lt 4 ]] && _prog_bar_total=4
  dbg "_prog_total_line: total=$_prog_total total_str=$_prog_total_str bar_total=$_prog_bar_total cols=$cols"
}

_prog_file_line() {
  [[ ! $show_progress ]] && return
  # $1=size $2=filename (full path ok; basename shown in bar)
  _prog_fname=$(basename "$2")
  dbg "_prog_file_line: fname=$_prog_fname size=$1"
}

_prog_chunk_line() {
  [[ ! $show_progress ]] && return
  _prog_done=$(( _prog_done + $1 ))
  dbg "_prog_chunk_line: chunk=$1 done=$_prog_done total=$_prog_total"
  _prog_render
}

_prog_done_line() {
  [[ ! $show_progress ]] && return
  # Force 100% on completion: tar/zip don't always emit a checkpoint for the
  # final partial block, leaving the bar short of 100%.
  [[ $_prog_total -gt 0 ]] && _prog_done=$_prog_total
  _prog_render
  printf '\n' >&2
}

# Find zip, tar or unzip sibling process; set compress_pid, compress_cwd, compress_tool.
compress_pid=
compress_cwd=
compress_tool=
ppid=$(awk '/^PPid:/{print $2}' /proc/self/status)
grandppid=$(awk '/^PPid:/{print $2}' /proc/"$ppid"/status 2>/dev/null)
for tool in zip tar unzip; do
  compress_pid=$(pgrep -P "$ppid" -x "$tool" 2>/dev/null | head -1)
  # Fallback: tool may be a sibling of the parent shell (grandparent of self)
  [[ ! $compress_pid ]] && compress_pid=$(pgrep -P "$grandppid" -x "$tool" 2>/dev/null | head -1)
  if [[ $compress_pid ]]; then
    compress_cwd=$(readlink /proc/"$compress_pid"/cwd 2>/dev/null)
    compress_tool=$tool
    break
  fi
done
if [[ ! $compress_tool ]]; then
  # Process finished before pgrep could detect it (small/fast archive).
  # Buffer all stdin, detect tool from output format, emit TOTAL+FILE via stat.
  compress_cwd=$PWD
  mapfile -t stdin_lines
  compress_tool=tar
  if [[ ${stdin_lines[0]-} == 'Archive:'* ]]; then
    compress_tool=unzip
    unzip_dest=$PWD
    [[ $unzip_dest != '/' ]] && unzip_dest=${unzip_dest%/}
  elif [[ ${stdin_lines[0]-} =~ ^[[:space:]]+(adding|updating): ]]; then
    compress_tool=zip
  fi
  dbg "fallback: tool=$compress_tool cwd=$compress_cwd lines=${#stdin_lines[@]}"
  fallback_fnames=()
  fallback_fsizes=()
  total_bytes=0
  for line in "${stdin_lines[@]}"; do
    case $compress_tool in
      unzip)
        # unzip stdout: " inflating: /dest/path/file.txt  " or " creating: dir/"
        [[ $line =~ ^[[:space:]]+(inflating|extracting|creating):[[:space:]]+(.+) ]] || continue
        candidate="${BASH_REMATCH[2]}"
        # Strip unzip's trailing padding spaces (format: "%-22s  %s%s")
        candidate="${candidate%"${candidate##*[! ]}"}"
        # Strip dest prefix so FILE output is dest-relative (e.g. "subdir/file.txt").
        # In the fallback compress_cwd=$PWD=unzip_dest, so fname is also stat-able
        # from CWD — no separate fpath needed, unlike the live reader path.
        fname="${candidate#"$unzip_dest"/}"
        ;;
      zip)
        # zip stdout: "  adding: path/to/file.js (2.0M)  (deflated 72%)"
        [[ $line =~ (adding|updating):\ (.*)\ \(([0-9.]+[KMGT]?)\)\  ]] || continue
        fname="${BASH_REMATCH[2]}"
        ;;
      tar)
        # tar stdout: one filename per line; "CHUNK" sentinels are skipped.
        # GNU tar escapes special chars (\n → literal \n); printf '%b' reverses that.
        [[ $line == 'CHUNK' || ! $line ]] && continue
        fname=$(printf '%b' "$line")
        ;;
    esac
    # All tools: fname is relative to CWD (= compress_cwd = PWD in fallback).
    fsize=$(stat -c%s -- "$fname" 2>/dev/null || echo 0)
    fallback_fnames+=("$fname")
    fallback_fsizes+=("$fsize")
    total_bytes=$(( total_bytes + fsize ))
  done
  if [[ $total_bytes -gt 0 ]]; then
    printf 'TOTAL %s\n' "$total_bytes"
    _prog_total_line "$total_bytes"
  fi
  for i in "${!fallback_fnames[@]}"; do
    printf 'FILE %(%s)T %s %s\n' -1 "${fallback_fsizes[$i]}" "${fallback_fnames[$i]}"
    _prog_file_line "${fallback_fsizes[$i]}" "${fallback_fnames[$i]}"
  done
  _prog_done_line
  exit 0
fi

# Emit TOTAL line
dbg "found process: pid=$compress_pid cwd=$compress_cwd tool=$compress_tool"
# Read cmdline of the compress process via /proc (null-delimited args).
mapfile -d '' cmdline_args < /proc/"$compress_pid"/cmdline
if [[ $compress_tool == unzip ]]; then
  # Find archive path: first non-option argument after binary name
  archive=""
  for arg in "${cmdline_args[@]:1}"; do
    [[ $arg == -* ]] && continue
    archive="$arg"
    break
  done
  dbg "unzip archive=$archive"
  # Find dest dir: -d option, else compress_cwd
  unzip_dest="$compress_cwd"
  next_is_dest=
  for arg in "${cmdline_args[@]:1}"; do
    if [[ $next_is_dest ]]; then
      unzip_dest="$arg"
      next_is_dest=
    elif [[ $arg == '-d' ]]; then
      next_is_dest=1
    fi
  done
  # Normalize unzip_dest: strip trailing slash (except lone root "/") so
  # "${candidate#\"$unzip_dest\"/}" strips correctly even if user passed -d /tmp/.
  [[ $unzip_dest != '/' ]] && unzip_dest=${unzip_dest%/}
  dbg "unzip dest=$unzip_dest"
  # Build fname→size lookup from manifest. Used by the stdout reader below.
  # unzip -l: "  1234567  2000-01-01 12:00   path/to/file.txt"  (Debian/ISO)
  # unzip -l: "  1234567  03-22-2026 20:43   path/to/file.txt"  (Info-ZIP/US)
  # Note: unzip -l escapes control chars as caret notation (^J etc.); filenames
  # with real control chars may not match the unzip stdout output, so their size
  # defaults to 0 (no CHUNK lines emitted, but FILE lines still appear).
  declare -A fname_to_size
  total_bytes=0
  while IFS= read -r line; do
    if [[ $line =~ ^[[:space:]]*([0-9]+)[[:space:]]+([0-9]{4}-[0-9]{2}-[0-9]{2}|[0-9]{2}-[0-9]{2}-[0-9]{4})[[:space:]]+[0-9]{2}:[0-9]{2}[[:space:]]+(.+)$ ]]; then
      fsize="${BASH_REMATCH[1]}"
      fname="${BASH_REMATCH[3]}"
      fname_to_size[$fname]=$fsize
      total_bytes=$(( total_bytes + fsize ))
    fi
  done < <(LANG=en_US.UTF-8 unzip -l "$archive" 2>/dev/null)
  dbg "total_bytes=$total_bytes files=${#fname_to_size[@]}"
  if [[ $total_bytes -gt 0 ]]; then
    printf 'TOTAL %s\n' "$total_bytes"
    _prog_total_line "$total_bytes"
  fi

# zip/tar: sum sizes of source files (args after '--'); also extract chunk size for CHUNK lines
else
  sources=()
  in_files=0
  chunk_bytes=0
  dot_size_str=
  # dot_record_size and dot_checkpoint: tar emits one DOT per (record_size * checkpoint) bytes.
  # zip emits one dot per --dot-size bytes. Both are parsed from the parent cmdline.
  dot_record_size=512
  dot_checkpoint=10
  next_is_dot_size=
  next_is_record_size=
  next_is_checkpoint=
  next_is_blocking_factor=
  is_tar_extract=
  tar_archive=
  tar_compress_prog=
  next_is_file=
  next_is_compress_prog=
  for arg in "${cmdline_args[@]:1}"; do   # skip binary name itself
    if [[ $in_files -eq 1 ]]; then
      sources+=("$arg")
    elif [[ $arg == '--' ]]; then
      in_files=1
    elif [[ $next_is_dot_size ]]; then
      dot_size_str=$arg
      next_is_dot_size=
    elif [[ $arg == '--dot-size' || $arg == '-ds' ]]; then
      next_is_dot_size=1
    elif [[ $arg =~ ^--dot-size=(.+)$ ]]; then
      dot_size_str=${BASH_REMATCH[1]}
    elif [[ $next_is_record_size ]]; then
      dot_record_size=$arg
      next_is_record_size=
    elif [[ $arg == '--record-size' ]]; then
      next_is_record_size=1
    elif [[ $arg =~ ^--record-size=([0-9]+)$ ]]; then
      dot_record_size=${BASH_REMATCH[1]}
    elif [[ $next_is_blocking_factor ]]; then
      dot_record_size=$((arg * 512))
      next_is_blocking_factor=
    elif [[ $arg == '--blocking-factor' || $arg == '-b' ]]; then
      next_is_blocking_factor=1
    elif [[ $arg =~ ^--blocking-factor=([0-9]+)$ ]]; then
      dot_record_size=$((BASH_REMATCH[1] * 512))
    elif [[ $arg =~ ^-b([0-9]+)$ ]]; then
      dot_record_size=$((BASH_REMATCH[1] * 512))
    elif [[ $next_is_checkpoint ]]; then
      dot_checkpoint=$arg
      next_is_checkpoint=
    elif [[ $arg == '--checkpoint' ]]; then
      next_is_checkpoint=1
    elif [[ $arg =~ ^--checkpoint=([0-9]+)$ ]]; then
      dot_checkpoint=${BASH_REMATCH[1]}
    elif [[ $next_is_file ]]; then
      tar_archive=$arg
      next_is_file=
    elif [[ $arg == '--file' ]]; then
      next_is_file=1
    elif [[ $arg =~ ^--file=(.+)$ ]]; then
      tar_archive=${BASH_REMATCH[1]}
    elif [[ $next_is_compress_prog ]]; then
      tar_compress_prog=$arg
      next_is_compress_prog=
    elif [[ $arg == '--use-compress-program' || $arg == '-I' ]]; then
      next_is_compress_prog=1
    elif [[ $arg =~ ^--use-compress-program=(.+)$ ]]; then
      tar_compress_prog=${BASH_REMATCH[1]}
    elif [[ $arg == '--extract' || $arg == '--get' ]]; then
      is_tar_extract=1
    elif [[ $arg =~ ^-[a-zA-Z] ]]; then
      # combined short flags: detect -x (extract) and -f (archive = next arg)
      [[ $arg =~ x ]] && is_tar_extract=1
      [[ $arg =~ f ]] && next_is_file=1
    fi
  done
  if [[ $dot_size_str ]]; then
    dot_val=${dot_size_str%[kKmMgG]}
    dot_unit=${dot_size_str##*[0-9]}
    case "${dot_unit,,}" in
      k) chunk_bytes=$((dot_val * 1024)) ;;
      m) chunk_bytes=$((dot_val * 1024 * 1024)) ;;
      g) chunk_bytes=$((dot_val * 1024 * 1024 * 1024)) ;;
      *) chunk_bytes=$dot_val ;;
    esac
  elif [[ $compress_tool == tar ]]; then
    chunk_bytes=$((dot_record_size * dot_checkpoint))
  fi
  dbg "sources: ${sources[*]} chunk_bytes=$chunk_bytes dot_size_str=$dot_size_str dot_record_size=$dot_record_size dot_checkpoint=$dot_checkpoint"
  dbg "is_tar_extract=$is_tar_extract tar_archive=$tar_archive tar_compress_prog=$tar_compress_prog"
  if [[ ${#sources[@]} -gt 0 ]]; then
    if [[ $compress_cwd ]]; then
      total_bytes=$(cd "$compress_cwd" && du -sb "${sources[@]}" 2>/dev/null | awk '{sum+=$1} END {print sum}')
    else
      total_bytes=$(du -sb "${sources[@]}" 2>/dev/null | awk '{sum+=$1} END {print sum}')
    fi
    dbg "total_bytes=$total_bytes"
    if [[ $total_bytes -gt 0 ]]; then
      printf 'TOTAL %s\n' "$total_bytes"
      _prog_total_line "$total_bytes"
    fi
  elif [[ $is_tar_extract && $tar_archive ]]; then
    # For tar extract: run tar -tvf with 5s timeout to get file sizes for TOTAL.
    # Plain tar listing is nearly instant; compressed formats are slower but usually finish
    # within the timeout for typical archive sizes. If the timeout is hit, TOTAL is skipped.
    listing_cmd=(tar)
    [[ $tar_compress_prog ]] && listing_cmd+=(--use-compress-program="$tar_compress_prog")
    listing_cmd+=(-tvf "$tar_archive")
    dbg "tar extract listing: ${listing_cmd[*]}"
    # Capture output first, then check exit code: a pipeline would lose timeout's exit code (124),
    # causing awk to sum partial output and emit an incorrect TOTAL lower than the actual size.
    listing_out=$(timeout 5 "${listing_cmd[@]}" 2>/dev/null)
    listing_rc=$?
    if [[ $listing_rc -eq 0 ]]; then
      total_bytes=$(awk '{sum+=$3} END {print sum+0}' <<< "$listing_out")
      if [[ $total_bytes -gt 0 ]]; then
        dbg "tar extract total_bytes=$total_bytes (from listing)"
        printf 'TOTAL %s\n' "$total_bytes"
        _prog_total_line "$total_bytes"
      fi
    else
      dbg "tar extract: listing timed out or failed (status=$listing_rc), no TOTAL"
    fi
  fi
fi

dbg "entering main progress loop..."
file_count=0

if [[ $compress_tool == unzip ]]; then
  # Read unzip stdout char-by-char with a 100ms read timeout.
  # Timing confirmed via strace:
  #   openat(O_CREAT|O_TRUNC)              ← T+0   file created empty
  #   write(1, " inflating: PATH  ", N)    ← T+64µs, one atomic write(2), NO \n
  #   <file data written>
  #   write(1, "\n", 1)                    ← after write completes
  #
  # Dual-trigger strategy:
  # 1. Timeout (rc > 128): no \n for 100ms. Because unzip writes the filename line
  #    in one atomic write(2) syscall, the buffer now holds the complete line —
  #    the full filename is available regardless of embedded spaces. File is being
  #    written right now → emit FILE, poll growth.
  # 2. \n arrival (rc == 0, char empty): file write complete. Handles small/fast
  #    files that finish before the 100ms timeout fires → emit FILE, no CHUNK.
  # already_handled: set by the timeout path; prevents the \n path from re-processing
  # the same line (defensive — the drain loop usually consumes the \n first).
  # Reset by whichever path handles the line.
  # Note: filenames with real control chars use caret notation in both unzip -l and
  # stdout (FnFilter1). The manifest lookup still works (same notation), but the
  # on-disk filename differs → CHUNK poll path uses a wrong fpath; FILE still appears.
  dbg "unzip stdout reader start: dest=$unzip_dest files=${#fname_to_size[@]}"
  char_buf=""
  already_handled=
  stall_buf=__unset__
  while true; do
    IFS= read -r -n 1 -t 0.1 char
    rc=$?
    if [[ $rc -eq 0 ]]; then
      # rc=0: read consumed exactly one byte.
      # Empty $char: the byte was the \n line delimiter — bash consumed it but does
      # not store it in the variable. Non-empty $char: regular byte, accumulate it.
      if [[ ! $char ]]; then
        # \n received: file write is complete.
        if [[ ! $already_handled ]]; then
          if [[ $char_buf =~ ^[[:space:]]+(inflating|extracting|creating):[[:space:]]+(.+) ]]; then
            candidate="${BASH_REMATCH[2]}"
            # Strip unzip's trailing padding spaces. Format: "%-22s  %s%s" pads
            # the filename field to at least 22 chars, then adds 2 separator spaces.
            # Example input:  "  inflating: tmp/file.txt           "
            # After strip:    "tmp/file.txt"
            candidate="${candidate%"${candidate##*[! ]}"}"
            fname="${candidate#"$unzip_dest"/}"
            # \n arrived → file write is complete. Emit FILE directly from manifest.
            if [[ ${fname_to_size[$fname]+x} ]]; then
              fsize="${fname_to_size[$fname]}"
            else
              printf 'Error: unzip manifest miss (\\n path): %s\n' "$fname" >&2
              [[ $fname == *'^'* || $fname == *'#U'* ]] && printf 'Error: filename contains escape sequences; make sure unzip is called with LANG=en_US.UTF-8\n' >&2
              fsize=0
            fi
            printf 'FILE %(%s)T %s %s\n' -1 "$fsize" "$fname"
            _prog_file_line "$fsize" "$fname"
            file_count=$(( file_count + 1 ))
          fi
        fi
        char_buf=""
        already_handled=
        continue
      fi
      char_buf+="$char"
      continue
    fi
    # rc != 0: read returned an error code.
    # rc in 1..128: EOF — unzip finished and closed the pipe. Exit the loop.
    [[ $rc -le 128 ]] && break
    # rc > 128: read -t timed out. Bash sets rc to 128 + signal number; on Linux
    # typically 142 (128 + SIGALRM=14). Portable check: rc > 128.
    # No \n arrived for 100ms → the atomic write(2) of the filename line is done;
    # the file is being written right now → emit FILE, start growth monitoring.
    if ! [[ $char_buf =~ ^[[:space:]]+(inflating|extracting|creating):[[:space:]]+(.+) ]]; then
      # Regex did not match. If char_buf has not grown since the last failed check,
      # unzip output is stuck/unexpected — bail out to avoid spinning forever.
      if [[ $char_buf == "$stall_buf" ]]; then
        printf 'Error: unzip stdout stalled (unexpected output): %q\n' "$char_buf" >&2
        break
      fi
      stall_buf=$char_buf
      continue
    fi
    stall_buf=__unset__
    candidate="${BASH_REMATCH[2]}"
    # Strip trailing padding spaces. Unzip format: "%-22s  %s%s" pads the filename
    # field to >=22 chars then adds 2 separator spaces before the trailing state.
    # Example: "  inflating: tmp/file.txt           " → "tmp/file.txt"
    candidate="${candidate%"${candidate##*[! ]}"}"
    # With -d /dest/dir unzip shows the full path: "inflating: /dest/dir/file.txt" → absolute.
    # Without -d it shows a path relative to its CWD: "inflating: file.txt" → prepend CWD.
    [[ $candidate != /* ]] && fpath="$compress_cwd/$candidate" || fpath="$candidate"
    fname="${candidate#"$unzip_dest"/}"
    already_handled=1
    if [[ ${fname_to_size[$fname]+x} ]]; then
      fsize="${fname_to_size[$fname]}"
    else
      printf 'Error: unzip manifest miss (timeout path): %s\n' "$fname" >&2
      [[ $fname == *'^'* || $fname == *'#U'* ]] && printf 'Error: filename contains escape sequences; make sure unzip is called with LANG=en_US.UTF-8\n' >&2
      fsize=0
    fi
    printf 'FILE %(%s)T %s %s\n' -1 "$fsize" "$fname"
    _prog_file_line "$fsize" "$fname"
    file_count=$(( file_count + 1 ))
    if [[ $fsize -gt 0 ]]; then
      prev_size=0
      while true; do
        cur_size=$(stat -c%s -- "$fpath" 2>/dev/null || echo 0)
        if [[ $cur_size -gt $prev_size ]]; then
          printf 'CHUNK %s %s\n' "$EPOCHREALTIME" "$((cur_size - prev_size))"
          _prog_chunk_line "$((cur_size - prev_size))"
          prev_size=$cur_size
          [[ $cur_size -ge $fsize ]] && break
        else
          break
        fi
        "$_sleep_cmd" 0.2
      done
    fi
    char_buf=""
    already_handled=
    # Drain rest of line (\n arrives after file write completes).
    while IFS= read -r -n 1 c; do [[ ! $c ]] && break; done
  done
  dbg "unzip done: file_count=$file_count"

else
  # Char-by-char parser for zip and tar compress (stdin is live, not pre-buffered).
  char_count=0
  first_char_received=
  dot_mode=
  line_buffer=
  while IFS= read -r -n1 char || [[ $char ]]; do
  char_count=$((char_count + 1))
  if [[ ! $first_char_received ]]; then
    dbg "first char received from stdin"
    first_char_received=1
  fi
  if [[ $((char_count % 500)) -eq 0 ]]; then
    dbg "char_count=$char_count file_count=$file_count dot_mode=$dot_mode"
  fi
  if [[ ! $dot_mode ]]; then
    line_buffer+="$char"

    # zip: "  adding: path/to/file.js (2.0M)  (deflated 72%)"
    # zip: "  adding: path/to/dir/ (stored 0%)"
    if [[ $line_buffer =~ (adding|updating):\ (.*)\ \(([0-9.]+[KMGT]?)\)\  ]]; then
      src_size="${BASH_REMATCH[3]}"
      fsize=$(awk -v s="$src_size" 'BEGIN{
        n=s+0
        if (s~/K/) print int(n*1024)
        else if (s~/M/) print int(n*1048576)
        else if (s~/G/) print int(n*1073741824)
        else if (s~/T/) print int(n*1099511627776)
        else print int(n)
      }')
      printf 'FILE %(%s)T %s %s\n' -1 "$fsize" "${BASH_REMATCH[2]}"
      _prog_file_line "$fsize" "${BASH_REMATCH[2]}"
      dot_mode=1
      file_count=$((file_count + 1))
    elif [[ ! $char ]]; then
      if [[ $line_buffer == 'CHUNK' ]]; then
        # tar: checkpoint sentinel written by --checkpoint-action=exec="printf 'CHUNK\n'"
        printf 'CHUNK %s %s\n' "$EPOCHREALTIME" "$chunk_bytes"
        _prog_chunk_line "$chunk_bytes"
      elif [[ $line_buffer ]]; then
        # tar: each line should be a filename; validate with stat to skip error messages.
        # GNU tar uses escape quoting style by default: \n → actual newline, \\ → backslash.
        # printf '%b' interprets these sequences to reconstruct the on-disk filename.
        fname=$(printf '%b' "$line_buffer")
        fsize=$(cd "$compress_cwd" && stat -c%s -- "$fname" 2>/dev/null)
        if [[ $fsize ]]; then
          printf 'FILE %(%s)T %s %s\n' -1 "$fsize" "$fname"
          _prog_file_line "$fsize" "$fname"
          file_count=$((file_count + 1))
        fi
      fi
      line_buffer=""
    fi

  else
    if [[ $char == '.' ]]; then
      # zip: dots on same line after file match, e.g. "....\n" (one dot per -ds Xm)
      printf 'CHUNK %s %s\n' "$EPOCHREALTIME" "$chunk_bytes"
      _prog_chunk_line "$chunk_bytes"
    elif [[ ! $char ]]; then
      # zip: newline ends dot/skip sequence; " (deflated X%)" or " (stored X%)" was discarded
      dot_mode=
      line_buffer=""
    fi
    # all other chars (spaces, compression info suffix) are silently discarded in dot_mode
  fi
  done
  dbg "while loop exited: char_count=$char_count file_count=$file_count last_char=$(printf '%q' "$char")"

fi
_prog_done_line
