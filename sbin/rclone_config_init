#!/bin/bash
#
# script: rclone_config_init
#
# Keep the rclone config on persistent storage using the default runtime path.
# This helper must never break boot flow; keep execution non-fatal.
set +e
set +u
set +o pipefail

CONFIG="${1:-/boot/config}"
RCLONE_BOOT_DIR="$CONFIG/rclone/root"
RCLONE_BOOT_CONFIG="$RCLONE_BOOT_DIR/rclone.conf"
RCLONE_LEGACY_BOOT_CONFIG="$CONFIG/rclone/rclone.conf"
RCLONE_PLUGIN_BOOT_CONFIG="$CONFIG/plugins/rclone/.rclone.conf"
RCLONE_ROOT_PATH="${2:-/root/.config/rclone}"

if [[ "$RCLONE_ROOT_PATH" == *.conf ]]; then
  RCLONE_ROOT_DIR="$(dirname "$RCLONE_ROOT_PATH")"
else
  RCLONE_ROOT_DIR="$RCLONE_ROOT_PATH"
fi

RCLONE_ROOT_CONFIG="$RCLONE_ROOT_DIR/rclone.conf"

log_issue() {
  if declare -F log >/dev/null 2>&1; then
    log "$1"
  else
    echo "$1"
  fi
}

ensure_paths() {
  if ! mkdir -p "$(dirname "$RCLONE_BOOT_DIR")" "$(dirname "$RCLONE_ROOT_DIR")" 2>/dev/null; then
    log_issue "ERROR: failed to ensure rclone config parent directories exist"
    return 1
  fi
}

promote_existing_root_dir() {
  if [[ -d "$RCLONE_ROOT_DIR" && ! -L "$RCLONE_ROOT_DIR" && ! -e "$RCLONE_BOOT_DIR" ]]; then
    if mv "$RCLONE_ROOT_DIR" "$RCLONE_BOOT_DIR" 2>/dev/null; then
      return 0
    fi
    log_issue "ERROR: failed to move rclone runtime dir to $RCLONE_BOOT_DIR"
  fi
}

seed_boot_config() {
  [[ -e "$RCLONE_BOOT_CONFIG" ]] && return 0

  if ! mkdir -p "$RCLONE_BOOT_DIR" 2>/dev/null; then
    log_issue "ERROR: failed to create $RCLONE_BOOT_DIR"
    return 1
  fi

  if [[ -f "$RCLONE_ROOT_CONFIG" && ! -L "$RCLONE_ROOT_CONFIG" && "$RCLONE_ROOT_CONFIG" != "$RCLONE_BOOT_CONFIG" ]]; then
    if mv "$RCLONE_ROOT_CONFIG" "$RCLONE_BOOT_CONFIG" 2>/dev/null; then
      return 0
    fi
    log_issue "ERROR: failed to move rclone runtime config to $RCLONE_BOOT_CONFIG"
    return 1
  fi

  if [[ -f "$RCLONE_LEGACY_BOOT_CONFIG" ]]; then
    if mv "$RCLONE_LEGACY_BOOT_CONFIG" "$RCLONE_BOOT_CONFIG" 2>/dev/null; then
      return 0
    fi
    log_issue "ERROR: failed to move legacy rclone config to $RCLONE_BOOT_CONFIG"
    return 1
  fi

  if [[ -f "$RCLONE_PLUGIN_BOOT_CONFIG" ]]; then
    if cp -a -- "$RCLONE_PLUGIN_BOOT_CONFIG" "$RCLONE_BOOT_CONFIG" 2>/dev/null; then
      return 0
    fi
    log_issue "ERROR: failed to copy plugin rclone config to $RCLONE_BOOT_CONFIG"
    return 1
  fi

  if ! touch "$RCLONE_BOOT_CONFIG" 2>/dev/null; then
    log_issue "ERROR: failed to initialize rclone config at $RCLONE_BOOT_CONFIG"
    return 1
  fi
}

link_root_config_file() {
  if [[ ! -r "$RCLONE_BOOT_CONFIG" ]]; then
    log_issue "ERROR: refusing to replace rclone runtime config because $RCLONE_BOOT_CONFIG is missing or unreadable"
    return 1
  fi

  if [[ -L "$RCLONE_ROOT_CONFIG" ]]; then
    local link_target
    link_target=$(readlink -f "$RCLONE_ROOT_CONFIG" 2>/dev/null || readlink "$RCLONE_ROOT_CONFIG" 2>/dev/null || true)
    [[ "$link_target" == "$RCLONE_BOOT_CONFIG" ]] && return 0
    rm -f "$RCLONE_ROOT_CONFIG" 2>/dev/null || true
  elif [[ -e "$RCLONE_ROOT_CONFIG" ]]; then
    rm -f "$RCLONE_ROOT_CONFIG" 2>/dev/null || true
  fi

  if ! ln -s "$RCLONE_BOOT_CONFIG" "$RCLONE_ROOT_CONFIG" 2>/dev/null; then
    log_issue "ERROR: failed to link rclone runtime config to $RCLONE_BOOT_CONFIG"
    return 1
  fi
}

link_root_dir() {
  local link_target

  if [[ -L "$RCLONE_ROOT_DIR" ]]; then
    link_target=$(readlink -f "$RCLONE_ROOT_DIR" 2>/dev/null || readlink "$RCLONE_ROOT_DIR" 2>/dev/null || true)
    if [[ "$link_target" == "$RCLONE_BOOT_DIR" ]]; then
      return 0
    fi
    rm -f "$RCLONE_ROOT_DIR" 2>/dev/null || true
  fi

  if [[ ! -e "$RCLONE_ROOT_DIR" ]]; then
    if ln -s "$RCLONE_BOOT_DIR" "$RCLONE_ROOT_DIR" 2>/dev/null; then
      return 0
    fi
    log_issue "ERROR: failed to link rclone runtime dir to $RCLONE_BOOT_DIR"
    return 1
  fi

  # If the runtime directory already contains extra files, preserve it and link the config file.
  if [[ -z "$(find "$RCLONE_ROOT_DIR" -mindepth 1 -maxdepth 1 ! -name 'rclone.conf' -print -quit 2>/dev/null)" ]]; then
    rm -f "$RCLONE_ROOT_CONFIG" 2>/dev/null || true
    if rmdir "$RCLONE_ROOT_DIR" 2>/dev/null && ln -s "$RCLONE_BOOT_DIR" "$RCLONE_ROOT_DIR" 2>/dev/null; then
      return 0
    fi
  fi

  link_root_config_file
}

run_rclone_config_init() {
  ensure_paths || true
  promote_existing_root_dir || true
  seed_boot_config || true
  link_root_dir || true
}

run_rclone_config_init || log_issue "WARNING: rclone_config_init completed with non-fatal errors"
exit 0
